<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:FitnessApp.Views"
             xmlns:viewmodels="clr-namespace:FitnessApp.ViewModels"
             xmlns:models="clr-namespace:FitnessApp.Models"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             x:DataType="viewmodels:RemindersViewModel"
             x:Class="FitnessApp.Views.RemindersPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1B1B1F"
             Title="Daily Reminders">

    <views:PageTemplate PageTitle="Daily Reminders" ShowBackArrow="True" IsBusy="{Binding IsBusy}">
        <views:PageTemplate.PageContent>
            <ScrollView>
                <VerticalStackLayout Spacing="20" Padding="20,10">

                    <!-- ═══ Warning Permission Banner ═══ -->
                    <Border StrokeThickness="1"
                             Stroke="#FF5252"
                             BackgroundColor="#222226"
                             StrokeShape="RoundRectangle 20"
                             Padding="20"
                             IsVisible="{Binding ShowPermissionBanner}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Notifications Disabled"
                                   TextColor="#FF5252"
                                   FontFamily="SyneBold"
                                   FontSize="16" />
                            <Label Text="Rhino Fitness needs notification permissions to trigger daily logs and workout reminders. Please enable them in your device settings."
                                   TextColor="#D0D0D5"
                                   FontFamily="OpenSansRegular"
                                   FontSize="13" />
                            <Button Text="Go to Settings"
                                    Command="{Binding OpenSettingsCommand}"
                                    TextColor="White"
                                    BackgroundColor="#5B2A9E"
                                    CornerRadius="12"
                                    HeightRequest="40"
                                    FontFamily="OpenSansSemibold"
                                    HorizontalOptions="Start" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═══ Status Indicator ═══ -->
                    <Border StrokeThickness="0"
                            BackgroundColor="#222226"
                            StrokeShape="RoundRectangle 20"
                            Padding="20">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="System Status"
                                       TextColor="White"
                                       FontFamily="SyneBold"
                                       FontSize="16" />
                                <Label Text="Notification permissions checked automatically"
                                       TextColor="#D0D0D5"
                                       FontFamily="OpenSansRegular"
                                       FontSize="12" />
                            </VerticalStackLayout>
                            
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding PermissionStatusColor}"
                                    Padding="12,6"
                                    StrokeShape="RoundRectangle 10"
                                    VerticalOptions="Center">
                                <Label Text="{Binding PermissionStatusText}"
                                       TextColor="White"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ═══ Add Reminder Form ═══ -->
                    <Border StrokeThickness="0"
                            BackgroundColor="#222226"
                            StrokeShape="RoundRectangle 24"
                            Padding="20">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="Add New Reminder"
                                   TextColor="White"
                                   FontFamily="SyneBold"
                                   FontSize="18" />

                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" RowSpacing="12" ColumnSpacing="12">
                                <!-- Category Column -->
                                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <Label Text="Category"
                                           TextColor="#D0D0D5"
                                           FontSize="12"
                                           FontFamily="OpenSansSemibold" />
                                    <Picker SelectedItem="{Binding SelectedCategory}"
                                            ItemsSource="{Binding Categories}"
                                            IsEnabled="{Binding HasNotificationPermission}"
                                            TextColor="White"
                                            TitleColor="#D0D0D5"
                                            BackgroundColor="#2A2A2E"
                                            HeightRequest="44" />
                                </VerticalStackLayout>

                                <!-- Time Column -->
                                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <Label Text="Time"
                                           TextColor="#D0D0D5"
                                           FontSize="12"
                                           FontFamily="OpenSansSemibold" />
                                    <TimePicker Time="{Binding SelectedTime}"
                                                IsEnabled="{Binding HasNotificationPermission}"
                                                TextColor="White"
                                                BackgroundColor="#2A2A2E"
                                                HeightRequest="44" />
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Recurrence Pattern Selection Card -->
                            <Border BackgroundColor="#1B1B1F"
                                    StrokeThickness="1"
                                    Stroke="#3A3A40"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14">
                                <VerticalStackLayout Spacing="12">
                                    <Label Text="RECURRENCE TYPE"
                                           TextColor="#9B7FD4"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="11"
                                           CharacterSpacing="1" />

                                    <!-- Pattern Selection Buttons -->
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Text="Daily"
                                                Command="{Binding SelectRecurrenceTypeCommand}"
                                                CommandParameter="daily"
                                                BackgroundColor="{Binding DailyBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />

                                        <Button Grid.Column="1"
                                                Text="Weekly"
                                                Command="{Binding SelectRecurrenceTypeCommand}"
                                                CommandParameter="weekly"
                                                BackgroundColor="{Binding WeeklyBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />

                                        <Button Grid.Column="2"
                                                Text="Custom Interval"
                                                Command="{Binding SelectRecurrenceTypeCommand}"
                                                CommandParameter="custom_interval"
                                                BackgroundColor="{Binding CustomIntervalBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="11"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />
                                    </Grid>

                                    <!-- Weekly Days Selection (Visible when Pattern == 'weekly') -->
                                    <VerticalStackLayout Spacing="8" IsVisible="{Binding IsWeeklyPattern}" Margin="0,4,0,0">
                                        <Label Text="SELECT DAYS"
                                               TextColor="#9B7FD4"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="11"
                                               CharacterSpacing="1" />
                                        <CollectionView ItemsSource="{Binding WeekDays}"
                                                        HeightRequest="42">
                                            <CollectionView.ItemsLayout>
                                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                            </CollectionView.ItemsLayout>
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate x:DataType="viewmodels:DayOfWeekChip">
                                                    <Button Text="{Binding DisplayName}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:RemindersViewModel}}, Path=ToggleDayCommand}"
                                                            CommandParameter="{Binding .}"
                                                            BackgroundColor="{Binding ChipBgColor}"
                                                            TextColor="White"
                                                            BorderColor="{Binding ChipBorderColor}"
                                                            BorderWidth="1"
                                                            CornerRadius="10"
                                                            FontFamily="OpenSansSemibold"
                                                            FontSize="12"
                                                            Padding="0"
                                                            WidthRequest="42"
                                                            HeightRequest="38" />
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>

                                    <!-- Custom Interval Inputs (Visible when Pattern == 'custom_interval') -->
                                    <VerticalStackLayout Spacing="10" IsVisible="{Binding IsCustomIntervalPattern}" Margin="0,4,0,0">
                                        <Label Text="REPEAT INTERVAL"
                                               TextColor="#9B7FD4"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="11"
                                               CharacterSpacing="1" />
                                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                                            <Entry Grid.Column="0"
                                                   Text="{Binding IntervalValue}"
                                                   Keyboard="Numeric"
                                                   TextColor="White"
                                                   BackgroundColor="#2A2A2E"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="14"
                                                   HeightRequest="40" />
                                            <Picker Grid.Column="1"
                                                    SelectedItem="{Binding IntervalUnit}"
                                                    TextColor="White"
                                                    BackgroundColor="#2A2A2E"
                                                    FontFamily="OpenSansSemibold"
                                                    FontSize="14"
                                                    HeightRequest="40">
                                                <Picker.ItemsSource>
                                                    <x:Array Type="{x:Type x:String}">
                                                        <x:String>days</x:String>
                                                        <x:String>weeks</x:String>
                                                    </x:Array>
                                                </Picker.ItemsSource>
                                            </Picker>
                                        </Grid>

                                        <Label Text="REQUIRED END DATE &amp; TIME"
                                               TextColor="#9B7FD4"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="11"
                                               CharacterSpacing="1" />
                                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                                            <DatePicker Grid.Column="0"
                                                        Date="{Binding EndDate}"
                                                        TextColor="White"
                                                        BackgroundColor="#2A2A2E"
                                                        MinimumDate="{x:Static sys:DateTime.Today}"
                                                        HeightRequest="40" />
                                            <TimePicker Grid.Column="1"
                                                        Time="{Binding EndTime}"
                                                        TextColor="White"
                                                        BackgroundColor="#2A2A2E"
                                                        HeightRequest="40" />
                                        </Grid>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Save Button -->
                            <Button Text="Add Reminder"
                                    Command="{Binding AddReminderCommand}"
                                    IsEnabled="{Binding HasNotificationPermission}"
                                    TextColor="White"
                                    BackgroundColor="#5B2A9E"
                                    CornerRadius="14"
                                    HeightRequest="48"
                                    FontFamily="OpenSansSemibold" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═══ Active Reminders List ═══ -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Active Reminders"
                               TextColor="White"
                               FontFamily="SyneBold"
                               FontSize="18" />

                        <CollectionView ItemsSource="{Binding Reminders}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>
                            
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Padding="30" HorizontalOptions="Center" Spacing="8">
                                    <Path Data="M12,2A3,3 0 0,0 9,5V6H7A3,3 0 0,0 4,9V17L2,19V20H22V19L20,17V9A3,3 0 0,0 17,6H15V5A3,3 0 0,0 12,2M12,22A3,3 0 0,0 15,19H9A3,3 0 0,0 12,22Z"
                                          Fill="#88888C"
                                          Aspect="Uniform"
                                          WidthRequest="48"
                                          HeightRequest="48"
                                          HorizontalOptions="Center" />
                                    <Label Text="No active reminders set"
                                           TextColor="#D0D0D5"
                                           FontSize="14"
                                           FontFamily="OpenSansRegular"
                                           HorizontalOptions="Center" />
                                    <Label Text="Add reminders above to stay consistent."
                                           TextColor="#88888C"
                                           FontSize="12"
                                           FontFamily="OpenSansRegular"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Reminder">
                                    <Border StrokeThickness="0"
                                            BackgroundColor="#2A2A2E"
                                            StrokeShape="RoundRectangle 16"
                                            Padding="16">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                             
                                            <!-- Bell Icon Wrapper -->
                                            <Border Grid.Column="0"
                                                    WidthRequest="40" HeightRequest="40"
                                                    StrokeThickness="0"
                                                    BackgroundColor="#222226"
                                                    StrokeShape="RoundRectangle 20"
                                                    VerticalOptions="Center">
                                                <Path Data="M12,2A3,3 0 0,0 9,5V6H7A3,3 0 0,0 4,9V17L2,19V20H22V19L20,17V9A3,3 0 0,0 17,6H15V5A3,3 0 0,0 12,2M12,22A3,3 0 0,0 15,19H9A3,3 0 0,0 12,22Z"
                                                      Fill="#9B7FD4"
                                                      Aspect="Uniform"
                                                      WidthRequest="18"
                                                      HeightRequest="18"
                                                      HorizontalOptions="Center"
                                                      VerticalOptions="Center" />
                                            </Border>

                                            <!-- Category & Recurrence Details -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding Category}"
                                                       TextColor="White"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="16" />
                                                <Label Text="{Binding RecurrenceSummaryText}"
                                                       TextColor="#9B7FD4"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="13" />
                                            </VerticalStackLayout>

                                            <!-- Delete Button -->
                                            <Border Grid.Column="2"
                                                    StrokeThickness="0"
                                                    BackgroundColor="#222226"
                                                    WidthRequest="40" HeightRequest="40"
                                                    StrokeShape="RoundRectangle 20"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Center">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding BindingContext.DeleteReminderCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                      Fill="#FF5252"
                                                      Aspect="Uniform"
                                                      WidthRequest="16"
                                                      HeightRequest="16"
                                                      HorizontalOptions="Center"
                                                      VerticalOptions="Center" />
                                            </Border>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </views:PageTemplate.PageContent>
    </views:PageTemplate>
</ContentPage>
