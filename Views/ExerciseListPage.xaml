<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:FitnessApp.Views"
             xmlns:viewmodels="clr-namespace:FitnessApp.ViewModels"
             xmlns:models="clr-namespace:FitnessApp.Models"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:converters="clr-namespace:FitnessApp.Converters"
             x:DataType="viewmodels:ExerciseListViewModel"
             x:Class="FitnessApp.Views.ExerciseListPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1B1B1F"
             Title="{Binding PageTitle}">

    <ContentPage.Resources>
        <converters:NullEmptyToBoolConverter x:Key="NullEmptyToBool" />
    </ContentPage.Resources>

    <views:PageTemplate PageTitle="{Binding PageTitle}" ShowBackArrow="True">
        <views:PageTemplate.PageContent>
            <Grid RowDefinitions="*, Auto">
                
                <!-- Loading -->
                <ActivityIndicator Grid.Row="0"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#9B7FD4"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center" />

                <!-- Empty state -->
                <Label Grid.Row="0"
                       Text="{Binding EmptyMessage}"
                       IsVisible="{Binding EmptyMessage, Converter={StaticResource NullEmptyToBool}}"
                       TextColor="#D0D0D5"
                       FontFamily="OpenSansRegular"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <!-- Exercise cards list -->
                <CollectionView Grid.Row="0"
                                ItemsSource="{Binding Exercises}"
                                Margin="20,8,20,8">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:SelectableExercise">
                            <Border StrokeThickness="0"
                                    BackgroundColor="#2A2A2E"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="0"
                                    Margin="0"
                                    HorizontalOptions="Center"
                                    MaximumWidthRequest="500">
                                <VerticalStackLayout Spacing="0">
                                    <!-- Exercise GIF -->
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 20,20,0,0"
                                            BackgroundColor="#ffffff"
                                            HeightRequest="250"
                                            Padding="0">
                                        <Grid>
                                            <Image Source="{Binding Exercise.GifUrl}"
                                                   Aspect="AspectFit"
                                                   HeightRequest="250"
                                                   IsAnimationPlaying="True" />
                                            
                                            <!-- Muscle Badge -->
                                            <Border BackgroundColor="#5B2A9E"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 4"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="End"
                                                    Margin="16"
                                                    Padding="8,4">
                                                <Label Text="{Binding Exercise.Muscle}"
                                                       TextColor="White"
                                                       FontFamily="OpenSansSemibold"
                                                       TextTransform="Uppercase"
                                                       FontSize="12" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Details -->
                                    <VerticalStackLayout Padding="20,16,20,20" Spacing="8">
                                        <!-- Exercise name & selection -->
                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Exercise.Name}"
                                                   TextColor="White"
                                                   FontFamily="SyneBold"
                                                   FontAttributes="Bold,Italic"
                                                   FontSize="20"
                                                   TextTransform="Uppercase"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2"
                                                   VerticalOptions="Center" />
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding IsSelected}"
                                                      Color="#9B7FD4"
                                                      VerticalOptions="Center" />
                                        </Grid>
                                        
                                        <!-- Instructions -->
                                        <Label Text="{Binding Exercise.Instructions}"
                                               TextColor="#D0D0D5"
                                               FontFamily="OpenSansRegular"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Bottom panel: Recurrence config & Add Button -->
                <VerticalStackLayout Grid.Row="1"
                                     Spacing="12"
                                     Margin="20,8,20,16"
                                     IsVisible="{Binding HasSelectedExercises}">

                    <!-- Recurrence Toggle & Configuration Card -->
                    <Border BackgroundColor="#222226"
                            StrokeThickness="1"
                            Stroke="#3A3A40"
                            StrokeShape="RoundRectangle 16"
                            Padding="16,14">
                        <VerticalStackLayout Spacing="14">
                            
                            <!-- Toggle Header -->
                            <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                    <Label Text="🔄" FontSize="18" VerticalOptions="Center" />
                                    <Label Text="Make Recurring"
                                           TextColor="White"
                                           FontFamily="SyneBold"
                                           FontSize="16"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding IsRecurring}"
                                        OnColor="#5B2A9E"
                                        ThumbColor="#9B7FD4" />
                            </Grid>

                            <!-- Recurrence Configuration Options -->
                            <VerticalStackLayout Spacing="14" IsVisible="{Binding IsRecurring}">
                                <BoxView HeightRequest="1" Color="#3A3A40" Margin="0,2" />

                                <!-- Pattern Selection Buttons -->
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="RECURRENCE PATTERN"
                                           TextColor="#9B7FD4"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="11"
                                           CharacterSpacing="1" />
                                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Text="Daily"
                                                Command="{Binding SelectPatternCommand}"
                                                CommandParameter="daily"
                                                BackgroundColor="{Binding DailyBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />

                                        <Button Grid.Column="1"
                                                Text="Weekly"
                                                Command="{Binding SelectPatternCommand}"
                                                CommandParameter="weekly"
                                                BackgroundColor="{Binding WeeklyBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />

                                        <Button Grid.Column="2"
                                                Text="Days"
                                                Command="{Binding SelectPatternCommand}"
                                                CommandParameter="specific_days"
                                                BackgroundColor="{Binding SpecificDaysBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />

                                        <Button Grid.Column="3"
                                                Text="Interval"
                                                Command="{Binding SelectPatternCommand}"
                                                CommandParameter="every_n"
                                                BackgroundColor="{Binding EveryNBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Specific Days Chips (Visible when Pattern == 'specific_days') -->
                                <VerticalStackLayout Spacing="8" IsVisible="{Binding IsSpecificDaysPattern}">
                                    <Label Text="SELECT DAYS"
                                           TextColor="#9B7FD4"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="11"
                                           CharacterSpacing="1" />
                                    <CollectionView ItemsSource="{Binding WeekDays}"
                                                    HeightRequest="42">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="viewmodels:DayOfWeekChip">
                                                <Button Text="{Binding DisplayName}"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ExerciseListViewModel}}, Path=ToggleDayCommand}"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="{Binding ChipBgColor}"
                                                        TextColor="White"
                                                        BorderColor="{Binding ChipBorderColor}"
                                                        BorderWidth="1"
                                                        CornerRadius="10"
                                                        FontFamily="OpenSansSemibold"
                                                        FontSize="12"
                                                        Padding="0"
                                                        WidthRequest="42"
                                                        HeightRequest="38" />
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>

                                <!-- Interval Inputs (Visible when Pattern == 'every_n') -->
                                <VerticalStackLayout Spacing="8" IsVisible="{Binding IsEveryNPattern}">
                                    <Label Text="INTERVAL VALUE"
                                           TextColor="#9B7FD4"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="11"
                                           CharacterSpacing="1" />
                                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                                        <Entry Grid.Column="0"
                                               Text="{Binding IntervalValue}"
                                               Keyboard="Numeric"
                                               TextColor="White"
                                               BackgroundColor="#2A2A2E"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="14"
                                               HeightRequest="40" />
                                        <Picker Grid.Column="1"
                                                SelectedItem="{Binding IntervalUnit}"
                                                TextColor="White"
                                                BackgroundColor="#2A2A2E"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="14"
                                                HeightRequest="40">
                                            <Picker.ItemsSource>
                                                <x:Array Type="{x:Type x:String}">
                                                    <x:String>days</x:String>
                                                    <x:String>weeks</x:String>
                                                </x:Array>
                                            </Picker.ItemsSource>
                                        </Picker>
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Duration / End Condition Selection -->
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="DURATION"
                                           TextColor="#9B7FD4"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="11"
                                           CharacterSpacing="1" />
                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Text="No End"
                                                Command="{Binding SelectEndTypeCommand}"
                                                CommandParameter="no_end"
                                                BackgroundColor="{Binding NoEndBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />

                                        <Button Grid.Column="1"
                                                Text="End Date"
                                                Command="{Binding SelectEndTypeCommand}"
                                                CommandParameter="end_date"
                                                BackgroundColor="{Binding EndDateBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />

                                        <Button Grid.Column="2"
                                                Text="Count"
                                                Command="{Binding SelectEndTypeCommand}"
                                                CommandParameter="occurrences"
                                                BackgroundColor="{Binding OccurrencesBgColor}"
                                                TextColor="White"
                                                FontFamily="OpenSansSemibold"
                                                FontSize="12"
                                                CornerRadius="10"
                                                Padding="0"
                                                HeightRequest="38" />
                                    </Grid>

                                    <!-- DatePicker (Visible when EndType == 'end_date') -->
                                    <DatePicker IsVisible="{Binding IsEndDate}"
                                                Date="{Binding EndDate}"
                                                TextColor="White"
                                                BackgroundColor="#2A2A2E"
                                                MinimumDate="{x:Static sys:DateTime.Today}"
                                                HeightRequest="40"
                                                Margin="0,4,0,0" />

                                    <!-- Occurrence Count Entry (Visible when EndType == 'occurrences') -->
                                    <Entry IsVisible="{Binding IsOccurrencesCount}"
                                           Text="{Binding OccurrenceCount}"
                                           Placeholder="Number of occurrences"
                                           PlaceholderColor="#888888"
                                           Keyboard="Numeric"
                                           TextColor="White"
                                           BackgroundColor="#2A2A2E"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="14"
                                           HeightRequest="40"
                                           Margin="0,4,0,0" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Add Selected Button -->
                    <Button Text="Add Selected Exercises"
                            Command="{Binding AddSelectedCommand}"
                            HeightRequest="50"
                            CornerRadius="25"
                            FontFamily="SyneBold"
                            FontSize="16"
                            TextColor="White"
                            BackgroundColor="#5B2A9E" />
                </VerticalStackLayout>
            </Grid>
        </views:PageTemplate.PageContent>
    </views:PageTemplate>
</ContentPage>
