<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:FitnessApp.Views"
             xmlns:viewmodels="clr-namespace:FitnessApp.ViewModels"
             xmlns:models="clr-namespace:FitnessApp.Models"
             x:DataType="viewmodels:ExerciseListViewModel"
             x:Class="FitnessApp.Views.ExerciseListPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1B1B1F"
             Title="{Binding PageTitle}"
             xmlns:converters="clr-namespace:FitnessApp.Converters">

    <ContentPage.Resources>
        <converters:NullEmptyToBoolConverter x:Key="NullEmptyToBool" />
    </ContentPage.Resources>

    <views:PageTemplate PageTitle="{Binding PageTitle}" ShowBackArrow="True">
        <views:PageTemplate.PageContent>
            <Grid>
                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#9B7FD4"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center" />

                <!-- Empty state -->
                <Label Text="{Binding EmptyMessage}"
                       IsVisible="{Binding EmptyMessage, Converter={StaticResource NullEmptyToBool}}"
                       TextColor="#D0D0D5"
                       FontFamily="OpenSansRegular"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <!-- Exercise cards -->
                <CollectionView ItemsSource="{Binding Exercises}"
                                Margin="20,8,20,0">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Exercise">
                            <Border StrokeThickness="0"
                                    BackgroundColor="#2A2A2E"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="0"
                                    Margin="0"
                                    HorizontalOptions="Center"
                                    MaximumWidthRequest="500">
                                <VerticalStackLayout Spacing="0">
                                    <!-- Exercise GIF -->
                                    <Border StrokeThickness="0"
                                            StrokeShape="RoundRectangle 20,20,0,0"
                                            BackgroundColor="#ffffff"
                                            HeightRequest="250"
                                            Padding="0">
                                        <Grid>
                                            <Image Source="{Binding GifUrl}"
                                                   Aspect="AspectFit"
                                                   HeightRequest="250"
                                                   IsAnimationPlaying="True" />
                                            
                                            <!-- Muscle Badge -->
                                            <Border BackgroundColor="#5B2A9E"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 4"
                                                    HorizontalOptions="Start"
                                                    VerticalOptions="End"
                                                    Margin="16"
                                                    Padding="8,4">
                                                <Label Text="{Binding Muscle}"
                                                       TextColor="White"
                                                       FontFamily="OpenSansSemibold"
                                                       TextTransform="Uppercase"
                                                       FontSize="12" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Details -->
                                    <VerticalStackLayout Padding="20,16,20,20" Spacing="8">
                                        <!-- Exercise name -->
                                        <Label Text="{Binding Name}"
                                               TextColor="White"
                                               FontFamily="SyneBold"
                                               FontAttributes="Bold,Italic"
                                               FontSize="20"
                                               TextTransform="Uppercase"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                        <!-- Instructions -->
                                        <Label Text="{Binding Instructions}"
                                               TextColor="#D0D0D5"
                                               FontFamily="OpenSansRegular"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </views:PageTemplate.PageContent>
    </views:PageTemplate>
</ContentPage>
