<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:FitnessApp.Views"
             xmlns:viewmodels="clr-namespace:FitnessApp.ViewModels"
             x:DataType="viewmodels:SignupViewModel"
             x:Class="FitnessApp.Views.SignupPage"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             BackgroundColor="#7c4ef6">

    <views:PageTemplate BackgroundColor="#7c4ef6" ShowBackArrow="True" ShowFooter="False" IsBusy="{Binding IsBusy}">
        <views:PageTemplate.PageContent>
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#7c4ef6" Offset="0.0" />
                        <GradientStop Color="#2c1464" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>

                <ScrollView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         Spacing="16"
                                         Padding="40,20,40,40">

                        <!-- Logo -->
                        <Image Source="logo.png"
                               HeightRequest="120"
                               WidthRequest="120"
                               HorizontalOptions="Center"
                               Margin="0,0,0,10" />

                        <Label Text="Create Account"
                               TextColor="White"
                               FontFamily="SyneBold"
                               FontSize="24"
                               HorizontalOptions="Center"
                               Margin="0,0,0,10" />

                        <!-- Name Field -->
                        <Border StrokeThickness="0"
                                BackgroundColor="#D6D6D6"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28">
                            <Entry Text="{Binding Name}"
                                   Placeholder="Username"
                                   PlaceholderColor="#555555"
                                   TextColor="#000000"
                                   FontFamily="OpenSansRegular"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Email Field -->
                        <Border StrokeThickness="0"
                                BackgroundColor="#D6D6D6"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28">
                            <Entry Text="{Binding Email}"
                                   Placeholder="Email Address"
                                   PlaceholderColor="#555555"
                                   TextColor="#000000"
                                   FontFamily="OpenSansRegular"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   Keyboard="Email" />
                        </Border>

                        <!-- Password Field -->
                        <Border StrokeThickness="0"
                                BackgroundColor="#D6D6D6"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28">
                            <Entry Text="{Binding Password}"
                                   Placeholder="Password"
                                   PlaceholderColor="#555555"
                                   TextColor="#000000"
                                   FontFamily="OpenSansRegular"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   IsPassword="True" />
                        </Border>

                        <!-- Confirm Password Field -->
                        <Border StrokeThickness="0"
                                BackgroundColor="#D6D6D6"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28">
                            <Entry Text="{Binding ConfirmPassword}"
                                   Placeholder="Confirm Password"
                                   PlaceholderColor="#555555"
                                   TextColor="#000000"
                                   FontFamily="OpenSansRegular"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"
                                   IsPassword="True" />
                        </Border>

                        <!-- Validation Error Display -->
                        <Label Text="{Binding ValidationError}"
                               TextColor="#FF5252"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               Margin="0,5,0,0"
                               IsVisible="{Binding ValidationError, Converter={StaticResource Key=NullEmptyToBoolConverter}}" />

                        <!-- Sign Up Button -->
                        <Border StrokeThickness="0"
                                BackgroundColor="#28272C"
                                HeightRequest="56"
                                StrokeShape="RoundRectangle 28"
                                Margin="0,10,0,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SignUpCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="Sign Up"
                                   TextColor="#D6D6D6"
                                   FontFamily="OpenSansSemibold"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Back to Login Navigation -->
                        <Label Text="Already have an account? Sign In"
                               TextColor="#9B7FD4"
                               FontFamily="OpenSansSemibold"
                               HorizontalOptions="Center"
                               Margin="0,15,0,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BackToLoginCommand}" />
                            </Label.GestureRecognizers>
                        </Label>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Informational Overlay for Offline Mode -->
                <Grid BackgroundColor="#D9000000"
                      IsVisible="{Binding IsOffline}"
                      InputTransparent="False">
                    <Border StrokeThickness="0"
                            BackgroundColor="#1B1B1F"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            Margin="40"
                            Padding="24"
                            StrokeShape="RoundRectangle 16"
                            WidthRequest="300">
                        <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                            <Label Text="No Internet Connection"
                                   TextColor="White"
                                   FontSize="20"
                                   FontFamily="SyneBold"
                                   HorizontalOptions="Center" />
                            <Label Text="An active internet connection is required to sign up or initialize your session."
                                   TextColor="#D6D6D6"
                                   FontSize="14"
                                   FontFamily="OpenSansRegular"
                                   HorizontalTextAlignment="Center"
                                   HorizontalOptions="Center" />
                            <ActivityIndicator IsRunning="True" Color="#9B7FD4" HeightRequest="40" WidthRequest="40" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </views:PageTemplate.PageContent>
    </views:PageTemplate>
</ContentPage>
