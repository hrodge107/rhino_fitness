<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:FitnessApp.Views"
             xmlns:viewmodels="clr-namespace:FitnessApp.ViewModels"
             xmlns:models="clr-namespace:FitnessApp.Models"
             x:DataType="viewmodels:ProfileViewModel"
             x:Class="FitnessApp.Views.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1B1B1F"
             Title="Profile">

    <views:PageTemplate PageTitle="Profile" ShowBackArrow="True" IsBusy="{Binding IsBusy}">
        <views:PageTemplate.PageContent>
            <ScrollView>
                <VerticalStackLayout Spacing="20" Padding="20,10">

                    <!-- ═══ Hero / User Info Section ═══ -->
                    <Border StrokeThickness="0"
                            BackgroundColor="#222226"
                            StrokeShape="RoundRectangle 24"
                            Padding="20">
                        <VerticalStackLayout Spacing="16">
                            
                            <!-- Header & Edit Toggle Button -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Personal Details"
                                       TextColor="White"
                                       FontFamily="SyneBold"
                                       FontSize="18"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                         Text="Edit info"
                                         Command="{Binding ToggleEditCommand}"
                                         IsEnabled="{Binding IsOnline}"
                                         TextColor="White"
                                         BackgroundColor="#5B2A9E"
                                         FontFamily="OpenSansSemibold"
                                         CornerRadius="12"
                                         HeightRequest="36"
                                         Padding="14,0"
                                         IsVisible="{Binding IsNotEditing}" />
                            </Grid>

                            <!-- Read-only Mode -->
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20" IsVisible="{Binding IsNotEditing}">
                                <!-- Circular Initials Avatar with Gradient Ring -->
                                <Border Grid.Column="0"
                                        WidthRequest="72"
                                        HeightRequest="72"
                                        StrokeThickness="3"
                                        StrokeShape="RoundRectangle 36"
                                        VerticalOptions="Center">
                                    <Border.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#9B7FD4" Offset="0.0" />
                                            <GradientStop Color="#5B2A9E" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Stroke>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3E1F6B" Offset="0.0" />
                                            <GradientStop Color="#222226" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Label Text="{Binding Initials}"
                                           TextColor="White"
                                           FontFamily="SyneBold"
                                           FontSize="26"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           TextColor="White"
                                           FontFamily="SyneBold"
                                           FontSize="24"
                                           LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                        <Label Text="{Binding Gender}"
                                               TextColor="#D0D0D5"
                                               FontFamily="OpenSansRegular"
                                               FontSize="14" />
                                        <Label Text="•" TextColor="#9B7FD4" VerticalOptions="Center" />
                                        <Label Text="{Binding Age, StringFormat='{0} years old'}"
                                               TextColor="#D0D0D5"
                                               FontFamily="OpenSansRegular"
                                               FontSize="14" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Edit Mode -->
                            <VerticalStackLayout Spacing="12" IsVisible="{Binding IsEditing}">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Name" TextColor="#D0D0D5" FontSize="12" FontFamily="OpenSansSemibold" />
                                    <Entry Text="{Binding EditName}"
                                           TextColor="White"
                                           BackgroundColor="#2A2A2E"
                                           Placeholder="Name"
                                           MaxLength="50" />
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="Gender" TextColor="#D0D0D5" FontSize="12" FontFamily="OpenSansSemibold" />
                                        <Picker SelectedItem="{Binding EditGender}"
                                                ItemsSource="{Binding GenderOptions}"
                                                TextColor="White"
                                                TitleColor="#D0D0D5"
                                                BackgroundColor="#2A2A2E" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="Age" TextColor="#D0D0D5" FontSize="12" FontFamily="OpenSansSemibold" />
                                        <Entry Text="{Binding EditAgeText}"
                                               TextColor="White"
                                               BackgroundColor="#2A2A2E"
                                               Placeholder="Age"
                                               Keyboard="Numeric" />
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Validation Error Message -->
                                <Label Text="{Binding ValidationError}"
                                       TextColor="#E53935"
                                       FontSize="13"
                                       FontFamily="OpenSansRegular"
                                       IsVisible="{Binding ValidationError, Converter={StaticResource Key=NullEmptyToBoolConverter}, ConverterParameter=True}" />

                                <!-- Edit Actions -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                                    <Button Grid.Column="0"
                                            Text="Cancel"
                                            Command="{Binding ToggleEditCommand}"
                                            TextColor="White"
                                            BackgroundColor="#444448"
                                            CornerRadius="14" />
                                    <Button Grid.Column="1"
                                            Text="Save"
                                            Command="{Binding SaveProfileCommand}"
                                            TextColor="White"
                                            BackgroundColor="#5B2A9E"
                                            CornerRadius="14" />
                                </Grid>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═══ Metrics Cards Section ═══ -->
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Body Metrics"
                                   TextColor="White"
                                   FontFamily="SyneBold"
                                   FontSize="18"
                                   VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    BackgroundColor="#2A2A2E"
                                    WidthRequest="36" HeightRequest="36"
                                    StrokeShape="RoundRectangle 18"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToEditMetricsCommand}" />
                                </Border.GestureRecognizers>
                                <!-- Pencil Edit Path -->
                                <Path Data="M3,17.25 V21 H6.75 L17.81,9.94 L14.06,6.19 Z M20.71,7.04 L17.96,4.29 L16.13,6.12 L18.88,8.87 Z"
                                      Fill="White"
                                      Aspect="Uniform"
                                      WidthRequest="16" HeightRequest="16"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" HeightRequest="120">
                            <!-- Height Card -->
                            <Border Grid.Column="0"
                                    StrokeThickness="0"
                                    BackgroundColor="#5B2A9E"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="10">
                                <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                                    <!-- Ruler Icon -->
                                    <Path Data="M2,2 H10 V22 H2 Z M6,6 H10 M6,10 H10 M6,14 H10 M6,18 H10"
                                          Fill="Transparent"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          Aspect="Uniform"
                                          WidthRequest="16" HeightRequest="16"
                                          HorizontalOptions="Center" />
                                    <Label Text="Height" TextColor="#E4E4E8" FontSize="11" FontFamily="OpenSansRegular" HorizontalOptions="Center" />
                                    <Label Text="{Binding HeightText}" TextColor="White" FontSize="16" FontFamily="SyneBold" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- Weight Card -->
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    BackgroundColor="#5B2A9E"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="10">
                                <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                                    <!-- Weight scale Icon -->
                                    <Path Data="M12,3A9,9 0 0,0 3,12A9,9 0 0,0 12,21A9,9 0 0,0 21,12A9,9 0 0,0 12,3M12,6A6,6 0 0,1 18,12C18,14.24 16.77,16.19 15,17.16V14.5A3,3 0 0,0 12,11.5A3,3 0 0,0 9,14.5V17.16C7.23,16.19 6,14.24 6,12A6,6 0 0,1 12,6"
                                          Fill="Transparent"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          Aspect="Uniform"
                                          WidthRequest="16" HeightRequest="16"
                                          HorizontalOptions="Center" />
                                    <Label Text="Weight" TextColor="#E4E4E8" FontSize="11" FontFamily="OpenSansRegular" HorizontalOptions="Center" />
                                    <Label Text="{Binding WeightText}" TextColor="White" FontSize="16" FontFamily="SyneBold" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <!-- BMI Card -->
                            <Border Grid.Column="2"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding BmiBgColor}"
                                    StrokeShape="RoundRectangle 20"
                                    Padding="8">
                                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                    <!-- Heartbeat Pulse Icon -->
                                    <Path Data="M3,12 H7 L9,7 L13,17 L15,10 L17,12 H21"
                                          Fill="Transparent"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          Aspect="Uniform"
                                          WidthRequest="16" HeightRequest="16"
                                          HorizontalOptions="Center" />
                                    <Label Text="BMI" TextColor="#E4E4E8" FontSize="11" FontFamily="OpenSansRegular" HorizontalOptions="Center" />
                                    <Label Text="{Binding BmiText}" TextColor="White" FontSize="16" FontFamily="SyneBold" HorizontalOptions="Center" />
                                    <Label Text="{Binding BmiStatus}" TextColor="White" FontSize="9" FontFamily="OpenSansSemibold" HorizontalOptions="Center" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- ═══ Daily Reminders Section ═══ -->
                    <Border StrokeThickness="0"
                            BackgroundColor="#222226"
                            StrokeShape="RoundRectangle 24"
                            Padding="20">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Daily Reminders"
                                       TextColor="White"
                                       FontFamily="SyneBold"
                                       FontSize="18" />
                                <Label Text="Configure alerts for meals, water, and workouts"
                                       TextColor="#D0D0D5"
                                       FontFamily="OpenSansRegular"
                                       FontSize="13" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    BackgroundColor="#5B2A9E"
                                    WidthRequest="40" HeightRequest="40"
                                    StrokeShape="RoundRectangle 20"
                                    HorizontalOptions="End"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToRemindersCommand}" />
                                </Border.GestureRecognizers>
                                <Path Data="M8.59,16.58 L13.17,12 L8.59,7.41 L10,6 L16,12 L10,18 L8.59,16.58 Z"
                                      Fill="White"
                                      Aspect="Uniform"
                                      WidthRequest="16" HeightRequest="16"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ═══ Activity Log Section ═══ -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Completed Activity"
                               TextColor="White"
                               FontFamily="SyneBold"
                               FontSize="18" />

                        <!-- Segmented Control Tab Bar -->
                        <Border StrokeThickness="1"
                                Stroke="#2A2A2E"
                                BackgroundColor="#222226"
                                StrokeShape="RoundRectangle 14"
                                HeightRequest="40"
                                Padding="2"
                                Margin="0,4,0,10">
                            <Grid x:Name="TabsGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Fluid Sliding Pill Background -->
                                <Border x:Name="CapsuleHighlight"
                                        Grid.Column="0"
                                        BackgroundColor="#5B2A9E"
                                        StrokeShape="RoundRectangle 12"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Fill"
                                        WidthRequest="0" />

                                <!-- Interactive Tab Labels -->
                                <Label x:Name="TabAll" Grid.Column="0" Text="All" TextColor="White" FontFamily="OpenSansSemibold" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="All" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="TabExercises" Grid.Column="1" Text="Exercises" TextColor="#D0D0D5" FontFamily="OpenSansSemibold" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="Exercises" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="TabMeal" Grid.Column="2" Text="Meal" TextColor="#D0D0D5" FontFamily="OpenSansSemibold" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="Meal" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="TabWater" Grid.Column="3" Text="Water" TextColor="#D0D0D5" FontFamily="OpenSansSemibold" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTabTapped" CommandParameter="Water" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>

                        <!-- Offline State Card -->
                        <Border StrokeThickness="1"
                                Stroke="#FF5252"
                                BackgroundColor="#222226"
                                StrokeShape="RoundRectangle 20"
                                Padding="24"
                                IsVisible="{Binding ShowOfflineState}">
                            <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                                <!-- Alert Icon -->
                                <Path Data="M12,2 L1,21 H23 Z M12,18 a1.5,1.5 0 1 1 0,-3 a1.5,1.5 0 0 1 0,3 Z M12,14 a1.5,1.5 0 0 1 -1.5,-1.5 v-4 a1.5,1.5 0 0 1 3,0 v4 a1.5,1.5 0 0 1 -1.5,1.5 Z"
                                      Fill="#FF5252"
                                      Aspect="Uniform"
                                      WidthRequest="24" HeightRequest="24"
                                      HorizontalOptions="Center" />
                                
                                <Label Text="Unable to load history while offline"
                                       TextColor="#D0D0D5"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center" />
                                
                                <Button Text="Retry Connection"
                                        Command="{Binding LoadProfileCommand}"
                                        TextColor="White"
                                        BackgroundColor="Transparent"
                                        BorderColor="#5B2A9E"
                                        BorderWidth="1.5"
                                        HeightRequest="36"
                                        CornerRadius="12"
                                        Padding="16,0"
                                        HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Empty State -->
                        <Border StrokeThickness="0"
                                BackgroundColor="#222226"
                                StrokeShape="RoundRectangle 20"
                                Padding="30"
                                IsVisible="{Binding ShowEmptyState}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding EmptyStateText}"
                                       TextColor="#D0D0D5"
                                       FontSize="14"
                                       FontFamily="OpenSansRegular"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding EmptyStateSubtext}"
                                       TextColor="#88888C"
                                       FontSize="12"
                                       FontFamily="OpenSansRegular"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Log List -->
                        <CollectionView ItemsSource="{Binding Activities}"
                                        IsVisible="{Binding ShowTimeline}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:TimelineActivityItem">
                                    <Grid ColumnDefinitions="30,*" ColumnSpacing="0">
                                        <!-- Timeline Indicator -->
                                        <Grid Grid.Column="0">
                                            <!-- Connected Vertical Line -->
                                            <BoxView WidthRequest="2"
                                                     BackgroundColor="#444448"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Fill" />
                                            <!-- Bullet Dot -->
                                            <Border WidthRequest="12" HeightRequest="12"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{Binding ThemeColor}"
                                                    StrokeShape="RoundRectangle 6"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="Center" />
                                        </Grid>

                                        <!-- Content Card -->
                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                BackgroundColor="#2A2A2E"
                                                StrokeShape="RoundRectangle 16"
                                                Padding="12"
                                                Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                                                <!-- Icon Container -->
                                                <Border Grid.Column="0"
                                                        WidthRequest="36" HeightRequest="36"
                                                        StrokeThickness="0"
                                                        BackgroundColor="#222226"
                                                        StrokeShape="RoundRectangle 18"
                                                        VerticalOptions="Center">
                                                    <Path Data="{Binding IconData}"
                                                          Fill="{Binding ThemeColor}"
                                                          Aspect="Uniform"
                                                          WidthRequest="18" HeightRequest="18"
                                                          HorizontalOptions="Center"
                                                          VerticalOptions="Center" />
                                                </Border>

                                                <!-- Texts -->
                                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                    <Label Text="{Binding Title}"
                                                           TextColor="White"
                                                           FontFamily="OpenSansSemibold"
                                                           FontSize="15"
                                                           LineBreakMode="TailTruncation" />
                                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                        <Label Text="{Binding Subtitle}"
                                                               TextColor="{Binding ThemeColor}"
                                                               FontFamily="OpenSansRegular"
                                                               FontSize="12" />
                                                        <Label Text="•"
                                                               TextColor="#88888C"
                                                               FontSize="12" />
                                                        <Label Text="{Binding Details}"
                                                               TextColor="#A0A0A0"
                                                               FontFamily="OpenSansRegular"
                                                               FontSize="12" />
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>

                                                <!-- Date -->
                                                <Label Grid.Column="2"
                                                       Text="{Binding DateText}"
                                                       TextColor="#D0D0D5"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="11"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Load More Button -->
                        <Button Text="Load More"
                                Command="{Binding LoadMoreCommand}"
                                IsVisible="{Binding LoadMoreVisible}"
                                TextColor="White"
                                BackgroundColor="#222226"
                                FontFamily="OpenSansSemibold"
                                CornerRadius="16"
                                HeightRequest="44"
                                Margin="0,8,0,20" />
                    </VerticalStackLayout>

                    <!-- Logout Section -->
                    <Button Text="Log Out"
                            Command="{Binding LogoutCommand}"
                            TextColor="#FF5252"
                            BackgroundColor="#222226"
                            BorderColor="#FF5252"
                            BorderWidth="1.5"
                            FontFamily="OpenSansSemibold"
                            CornerRadius="16"
                            HeightRequest="48"
                            Margin="0,10,0,30" />

                </VerticalStackLayout>
            </ScrollView>
        </views:PageTemplate.PageContent>
    </views:PageTemplate>
</ContentPage>
