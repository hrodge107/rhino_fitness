<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FitnessApp.ViewModels"
             xmlns:models="clr-namespace:FitnessApp.Models"
             x:DataType="viewmodels:HomeViewModel"
             x:Class="FitnessApp.Views.HomePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1B1B1F"
             Title="Home">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20,16">

            <!-- ═══ Top Bar ═══ -->
            <Grid ColumnDefinitions="48,*,48" HeightRequest="48">
                <!-- Mini Initials Avatar with Gradient Ring -->
                <Border Grid.Column="0"
                        WidthRequest="38" HeightRequest="38"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 19"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToProfileCommand}" />
                    </Border.GestureRecognizers>
                    <Border.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#9B7FD4" Offset="0.0" />
                            <GradientStop Color="#5B2A9E" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Stroke>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3E1F6B" Offset="0.0" />
                            <GradientStop Color="#222226" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Label Text="{Binding Initials}"
                           TextColor="White"
                           FontFamily="SyneBold"
                           FontSize="14"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <!-- Title -->
                <Label Grid.Column="1"
                       Text="Rhino Fitness"
                       TextColor="White"
                       FontFamily="SyneBold"
                       FontSize="18"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <!-- Hamburger — opens Shell flyout -->
                <Border Grid.Column="2"
                        StrokeThickness="0"
                        BackgroundColor="Transparent"
                        WidthRequest="40" HeightRequest="40"
                        HorizontalOptions="End"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnHamburgerTapped" />
                    </Border.GestureRecognizers>
                    <Path Data="M4,7 H20 M4,12 H20 M4,17 H20"
                          Stroke="White"
                          StrokeThickness="2.5"
                          StrokeLineCap="Round"
                          Aspect="Uniform"
                          WidthRequest="20" HeightRequest="20"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- ═══ Greeting ═══ -->
            <VerticalStackLayout Spacing="2" Padding="0,8,0,0">
                <Label FontSize="28"
                       FontFamily="SyneBold"
                       TextColor="White">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Hi, " FontAttributes="Bold" />
                            <Span Text="{Binding UserName}" FontAttributes="Bold" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label Text="{Binding CurrentDateText}"
                       TextColor="#D0D0D5"
                       FontSize="14"
                       FontFamily="OpenSansRegular" />
            </VerticalStackLayout>

            <!-- ═══ Hero / Progress Card ═══ -->
            <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="20"
                    HeightRequest="150">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#5B2A9E" Offset="0.0" />
                        <GradientStop Color="#9B7FD4" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,Auto">
                    <!-- Progress label -->
                    <Label Grid.Row="0" Grid.Column="0"
                           Text="TODAY'S PROGRESS"
                           TextColor="White"
                           FontFamily="SyneBold"
                           FontSize="12"
                           Opacity="0.8"
                           CharacterSpacing="1" />
                    
                    <!-- Progress fraction text -->
                    <Label Grid.Row="0" Grid.Column="1"
                           Text="{Binding ProgressText}"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           HorizontalOptions="End" />

                    <!-- Motivational text / large headline -->
                    <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="{Binding MotivationalText}"
                           TextColor="White"
                           FontFamily="SyneBold"
                           FontSize="18"
                           VerticalOptions="Center"
                           LineBreakMode="WordWrap" />

                    <!-- ProgressBar -->
                    <ProgressBar Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                 Progress="{Binding ProgressPercentage}"
                                 ProgressColor="White"
                                 HeightRequest="6"
                                 VerticalOptions="End" />
                </Grid>
            </Border>

            <!-- ═══ Calendar Week Strip ═══ -->
            <CollectionView ItemsSource="{Binding WeekDays}"
                            ItemsLayout="HorizontalList"
                            HeightRequest="80"
                            HorizontalOptions="Center">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DayModel">
                        <Border StrokeThickness="0"
                                WidthRequest="64"
                                HeightRequest="70"
                                Margin="6,0"
                                StrokeShape="RoundRectangle 16"
                                Padding="0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsToday}"
                                             Value="True">
                                     <Setter Property="BackgroundColor" Value="#5B2A9E" />
                                </DataTrigger>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsToday}"
                                             Value="False">
                                     <Setter Property="BackgroundColor" Value="#222226" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="2">
                                <Label Text="{Binding DayName}"
                                       FontSize="11"
                                       FontFamily="OpenSansRegular"
                                       HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsToday}"
                                                     Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsToday}"
                                                     Value="False">
                                            <Setter Property="TextColor" Value="#D0D0D5" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                                <Label Text="{Binding DayNumber}"
                                       FontSize="16"
                                       FontFamily="OpenSansSemibold"
                                       HorizontalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsToday}"
                                                     Value="True">
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding IsToday}"
                                                     Value="False">
                                            <Setter Property="TextColor" Value="#FFFFFF" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- ═══ Navigation Cards ═══ -->
            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="140,95"
                  ColumnSpacing="12"
                  RowSpacing="12"
                  Padding="0,8,0,0">

                <!-- Planner Card -->
                <Border Grid.Row="0" Grid.Column="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Padding="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#5B2A9E" Offset="0.0" />
                            <GradientStop Color="#6A2FB0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToPlannerCommand}" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <VerticalStackLayout Grid.Row="0" Spacing="2">
                            <Label Text="Planner"
                                   TextColor="White"
                                   FontFamily="SyneBold"
                                   FontSize="18" />
                            <Label Text="View Schedule"
                                   TextColor="#D0D0D5"
                                   FontFamily="OpenSansRegular"
                                   FontSize="12" />
                        </VerticalStackLayout>

                        <!-- Calendar Icon -->
                        <Path Grid.Row="1"
                              Data="M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3.01,4.9 3.01,6L3,20C3,21.1 3.89,22 5,22H19C20.1,22 21,21.1 21,20V6C21,4.9 20.1,4 19,4ZM19,20H5V9H19V20ZM9,11H7V13H9V11ZM13,11H11V13H13V11ZM17,11H15V13H17V11ZM9,15H7V17H9V15ZM13,15H11V17H13V15ZM17,15H15V17H17V15Z"
                              Fill="White"
                              Aspect="Uniform"
                              WidthRequest="32" HeightRequest="32"
                              HorizontalOptions="Start"
                              VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Workouts Card -->
                <Border Grid.Row="0" Grid.Column="1"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Padding="16">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6A2FB0" Offset="0.0" />
                            <GradientStop Color="#9B7FD4" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToWorkoutsCommand}" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <VerticalStackLayout Grid.Row="0" Spacing="2">
                            <Label Text="Workouts"
                                   TextColor="White"
                                   FontFamily="SyneBold"
                                   FontSize="18" />
                            <Label Text="Browse Exercises"
                                   TextColor="#D0D0D5"
                                   FontFamily="OpenSansRegular"
                                   FontSize="12" />
                        </VerticalStackLayout>
                        
                        <!-- Dumbbell SVG path -->
                        <Path Grid.Row="1"
                              Data="M5,6 H7 V18 H5 Z M8,8 H10 V16 H8 Z M10,11 H22 V13 H10 Z M22,8 H24 V16 H22 Z M25,6 H27 V18 H25 Z"
                              Fill="White"
                              Aspect="Uniform"
                              WidthRequest="36"
                              HeightRequest="36"
                              HorizontalOptions="Start"
                              VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Nutrition Card — spans full width -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        Padding="16"
                        HorizontalOptions="Fill">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3E1F6B" Offset="0.0" />
                            <GradientStop Color="#222226" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToNutritionCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Nutrition"
                                   TextColor="White"
                                   FontFamily="SyneBold"
                                   FontSize="18" />
                            <Label Text="Track Calories"
                                   TextColor="#D0D0D5"
                                   FontFamily="OpenSansRegular"
                                   FontSize="12" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                            <!-- Target Calorie display -->
                            <Label Text="{Binding TargetCaloriesText}"
                                   TextColor="#A88EDB"
                                   FontFamily="SyneBold"
                                   FontSize="16"
                                   VerticalOptions="Center" />

                            <!-- Flame Icon -->
                            <Path Data="M12,2C11.5,2 11,3 10.18,4.61C9.6,5.65 9.17,6.86 9.17,8.12C9.17,10.66 11.23,12.72 13.77,12.72C16.31,12.72 18.37,10.66 18.37,8.12C18.37,5.58 15,2 12,2Z"
                                  Fill="#9B7FD4"
                                  Aspect="Uniform"
                                  WidthRequest="22" HeightRequest="22"
                                  VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </Grid>

            <!-- ═══ Logo Footer ═══ -->
            <VerticalStackLayout HorizontalOptions="Center" Margin="0,20,0,10" Spacing="6">
                <Image Source="logo_purple.png"
                       HeightRequest="60"
                       WidthRequest="60"
                       HorizontalOptions="Center"
                       Opacity="0.85" />
                <Label Text="STRENGTH • RESILIENCE • MOMENTUM"
                       TextColor="#9B7FD4"
                       FontSize="10"
                       FontFamily="SyneBold"
                       CharacterSpacing="1.5"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
