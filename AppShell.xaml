<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FitnessApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FitnessApp"
    xmlns:views="clr-namespace:FitnessApp.Views"
    Title="FitnessApp"
    FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="#1B1B1F"
    Shell.ForegroundColor="White">

    <!-- Login — not shown in flyout -->
    <ShellContent ContentTemplate="{DataTemplate views:LoginPage}"
                  Route="LoginPage"
                  FlyoutItemIsVisible="False" />

    <!-- Flyout nav items -->
    <FlyoutItem Title="Home" Route="HomePage">
        <ShellContent ContentTemplate="{DataTemplate views:HomePage}" />
    </FlyoutItem>

    <FlyoutItem Title="Planner" Route="PlannerPage">
        <ShellContent ContentTemplate="{DataTemplate views:PlannerPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Workouts" Route="WorkoutsPage">
        <ShellContent ContentTemplate="{DataTemplate views:WorkoutsPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Nutrition" Route="NutritionPage">
        <ShellContent ContentTemplate="{DataTemplate views:NutritionPage}" />
    </FlyoutItem>

    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="20,40,20,20">
            <Label Text="Rhino Fitness"
                   TextColor="White"
                   FontFamily="SyneBold"
                   FontSize="22" />
            <BoxView HeightRequest="1"
                     Color="#5B2A9E"
                     Margin="0,12,0,0" />
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

</Shell>
